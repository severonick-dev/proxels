###############################################################################
# Proxels — пример переменных окружения.
# Скопировать в .env (НИКОГДА не коммитить .env!) и заполнить реальными значениями.
# Полный список наполняется по мере реализации этапов из prompts/CLAUDE.md §12.
###############################################################################

# --- Окружение -------------------------------------------------------------
NODE_ENV=development                       # development | production | test
APP_URL=http://localhost:5173              # публичный URL фронта
API_URL=http://localhost:3000              # публичный URL backend
API_PORT=3000
WEB_PORT=5173
LOG_LEVEL=info                             # pino: trace|debug|info|warn|error

# --- PostgreSQL ------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=proxels
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=proxels
DATABASE_URL=postgresql://proxels:change-me-strong-password@localhost:5432/proxels?schema=public

# --- Redis -----------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# --- JWT / Auth ------------------------------------------------------------
JWT_ACCESS_SECRET=change-me-min-32-chars-random
JWT_REFRESH_SECRET=change-me-min-32-chars-random-different
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false                        # true в production (HTTPS only)

# --- SMTP (транзакционные письма) -----------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Proxels <no-reply@proxels.ru>"

# --- ЮKassa ----------------------------------------------------------------
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_SECRET=                   # для проверки подписи (если будет настроено)
# Whitelist IP YooKassa для вебхуков — см. docs/SECURITY.md.

# --- Captcha (анти-бот) ----------------------------------------------------
# Yandex SmartCaptcha (РФ-актуально). Альтернатива — hCaptcha.
CAPTCHA_PROVIDER=yandex                    # yandex | hcaptcha | none(dev)
CAPTCHA_SITE_KEY=
CAPTCHA_SERVER_KEY=

# --- Реквизиты владельца (для футера, оферты, чеков ЮKassa) ---------------
OWNER_FIO="Коробейников Сергей Сергеевич"
OWNER_OGRNIP="324253600103000"
OWNER_INN="250501904935"
OWNER_ADDRESS="Приморский край, г. Дальнегорск, с. Краснореченский"
CONTACT_EMAIL=sergey.korobeynikov@lithops.group
CONTACT_TELEGRAM=https://t.me/proxels

# --- Админка ---------------------------------------------------------------
ADMIN_IP_ALLOWLIST=                        # CSV: 1.2.3.4,5.6.7.8 (пусто = без allowlist)

# --- SEO / Analytics -------------------------------------------------------
YANDEX_METRIKA_ID=
YANDEX_WEBMASTER_VERIFICATION=
GOOGLE_SEARCH_CONSOLE_VERIFICATION=

# --- Xray nodes (для backend, чтобы коннектиться по gRPC) -----------------
# Сами ноды (host, gRPC API) хранятся в БД. Здесь — только корневой ключ
# защищённого канала между backend и нодами (если используем mTLS/токен).
XRAY_NODE_API_TOKEN=change-me-shared-secret

# --- Прочее ----------------------------------------------------------------
DEFAULT_LOCALE=ru                          # ru | en
