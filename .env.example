###############################################################################
# Proxels — пример переменных окружения.
# Скопировать в .env (НИКОГДА не коммитить .env!) и заполнить реальными значениями.
# Полный список наполняется по мере реализации этапов из prompts/CLAUDE.md §12.
###############################################################################

# --- Окружение -------------------------------------------------------------
NODE_ENV=development                       # development | production | test
APP_URL=http://localhost:5173              # публичный URL фронта
API_URL=http://localhost:3000              # публичный URL backend
API_PORT=3000
WEB_PORT=5173
LOG_LEVEL=info                             # pino: trace|debug|info|warn|error

# --- PostgreSQL ------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=proxels
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=proxels
DATABASE_URL=postgresql://proxels:change-me-strong-password@localhost:5432/proxels?schema=public

# --- Redis -----------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# --- JWT / Auth ------------------------------------------------------------
JWT_ACCESS_SECRET=change-me-min-32-chars-random
JWT_REFRESH_SECRET=change-me-min-32-chars-random-different
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false                        # true в production (HTTPS only)

# --- SMTP (транзакционные письма) -----------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Proxels <no-reply@proxels.ru>"

# --- ЮKassa ----------------------------------------------------------------
# Если YOOKASSA_SHOP_ID пуст или = "test" — в development включается dev-bypass:
# реальный API не вызывается, выдаётся синтетический confirmation URL, и можно
# симулировать payment.succeeded через POST /api/payments/dev/simulate-succeeded/:id.
# В production пустые shopId/secretKey приведут к 500 при попытке создать платёж.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_SECRET=                   # на случай, если в кабинете включена подпись
YOOKASSA_RETURN_URL=                       # куда вернуть после оплаты; пусто → APP_URL/lk/payments

# Параметры фискального чека (54-ФЗ). Дефолты — для ИП на УСН/НПД (без НДС).
YOOKASSA_VAT_CODE=1                        # 1=без НДС, 3=10%, 4=20%, 5=10/110, 6=20/120
YOOKASSA_PAYMENT_MODE=full_prepayment      # full_prepayment | partial_prepayment | advance | full_payment | ...
YOOKASSA_PAYMENT_SUBJECT=service           # service | commodity | work | payment | ...

# CSV дополнительных IP/CIDR для webhook (поверх захардкоженного списка YooKassa).
YOOKASSA_EXTRA_WEBHOOK_IPS=

# Whitelist IP YooKassa захардкожен в yookassa-ip.guard.ts.
# При 403 на webhook проверь, что nginx прокидывает X-Forwarded-For и Express
# знает про trust proxy (см. Этап 13 docs/DEPLOY.md).

# --- Captcha (анти-бот) ----------------------------------------------------
# Yandex SmartCaptcha (РФ-актуально). Альтернатива — hCaptcha.
# В production значение `none` ЗАПРЕЩЕНО — сервис не стартует.
CAPTCHA_PROVIDER=yandex                    # yandex | hcaptcha | none (только dev)
CAPTCHA_SITE_KEY=
CAPTCHA_SERVER_KEY=

# --- Реквизиты владельца (для футера, оферты, чеков ЮKassa) ---------------
OWNER_FIO="Коробейников Сергей Сергеевич"
OWNER_OGRNIP="324253600103000"
OWNER_INN="250501904935"
OWNER_ADDRESS="Приморский край, г. Дальнегорск, с. Краснореченский"
CONTACT_EMAIL=noreply@proxels.ru             # ЗАМЕНИТЬ на реальный контактный email владельца
CONTACT_TELEGRAM=https://t.me/proxels

# --- Админка ---------------------------------------------------------------
ADMIN_IP_ALLOWLIST=                        # CSV: 1.2.3.4,5.6.7.8 (пусто = без allowlist)

# --- Seed (только для dev/staging; на проде admin создаём CLI-командой) ---
# Если оба заданы — prisma db seed создаст/обновит админа с этим email/паролем.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# --- SEO / Analytics -------------------------------------------------------
YANDEX_METRIKA_ID=
YANDEX_WEBMASTER_VERIFICATION=
GOOGLE_SEARCH_CONSOLE_VERIFICATION=

# --- Xray nodes (для backend, чтобы коннектиться по gRPC) -----------------
# Сами ноды (host, gRPC API) хранятся в БД. Здесь — корневой токен канала
# между backend и нодами (Authorization: Bearer <token> через gRPC metadata).
XRAY_NODE_API_TOKEN=change-me-shared-secret

# Реализация клиента к нодам:
#   noop — в dev, ничего не отправляет на ноды (просто логирует). Дефолт.
#   grpc — реальный gRPC (требует .proto-файлов, см. infra/xray/README.md).
# В production noop ЗАПРЕЩЁН (XrayModule бросит на старте).
XRAY_CLIENT=noop

# --- Health-check нод (Этап 11) -------------------------------------------
# BullMQ repeatable job: каждые N сек TCP-пробит каждую активную ноду на её
# xrayApiAddr (gRPC API адрес). Анти-флаппинг: M успехов подряд → online,
# K фейлов подряд → offline. Промежуточное → degraded.
HEALTH_CHECK_INTERVAL_SECONDS=30
HEALTH_CHECK_TIMEOUT_MS=3000
HEALTH_FLAP_UP_THRESHOLD=2
HEALTH_FLAP_DOWN_THRESHOLD=3

# --- Деплой через админку (Этап 13) ----------------------------------------
# `DEPLOY_ENABLED=true` включает кнопку «Обновить» в /admin/deploy. Только на
# прод-сервере, где установлен deploy.sh + sudoers-правило на systemctl.
# В dev — false. Status-эндпоинты работают всегда (UI можно тестить локально).
DEPLOY_ENABLED=false
DEPLOY_SCRIPT=/opt/proxels/infra/deploy/deploy.sh
DEPLOY_LOG_DIR=/var/log/proxels-deploy
# DEPLOY_REPO_DIR=/opt/proxels    # автоопределяется от cwd, переопределить можно

# --- Прочее ----------------------------------------------------------------
DEFAULT_LOCALE=ru                          # ru | en
